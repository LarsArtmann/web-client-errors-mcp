{
  "name": "web-client-errors-mcp",
  "version": "1.0.0",
  "description": "MCP server for detecting and analyzing client-side web errors - perfect for AI coding agents using CRUSH",
  "keywords": [
    "ai-agents",
    "browser-errors",
    "client-side-errors",
    "crush",
    "error-detection",
    "javascript-errors",
    "mcp",
    "model-context-protocol",
    "playwright",
    "web-monitoring"
  ],
  "homepage": "https://github.com/LarsArtmann/web-client-errors-mcp#readme",
  "bugs": {
    "url": "https://github.com/LarsArtmann/web-client-errors-mcp/issues"
  },
  "license": "MIT",
  "author": "Lars Artmann <lars@artmann.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/LarsArtmann/web-client-errors-mcp.git"
  },
  "type": "module",
  "main": "dist/core/mcp-server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "bun dist/core/mcp-server.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
